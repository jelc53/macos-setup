#!/bin/bash
set -euo pipefail

if [ $# -ne 1 ]; then
  echo "usage: extract <archive>" >&2
  exit 1
fi

if [ ! -f "$1" ]; then
  echo "not a file: $1" >&2
  exit 1
fi

case "$1" in
  *.tar.bz2|*.tbz2) tar xjf "$1" ;;
  *.tar.gz|*.tgz)   tar xzf "$1" ;;
  *.tar.xz|*.txz)   tar xJf "$1" ;;
  *.tar.zst)        tar --zstd -xf "$1" ;;
  *.tar)            tar xf "$1" ;;
  *.bz2)            bunzip2 "$1" ;;
  *.gz)             gunzip "$1" ;;
  *.xz)             unxz "$1" ;;
  *.zip)            unzip "$1" ;;
  *.7z)             7zz x "$1" ;;
  *) echo "unknown archive format: $1" >&2; exit 1 ;;
esac
